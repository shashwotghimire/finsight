// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

enum AccountType {
  PERSONAL
  JOINT
  SAVING
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum UserType {
  FREE
  PAID
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
}

enum TaxType {
  INCOME
  VAT
}

enum Currency {
  NPR
  USD
}

enum BudgetPeriod {
  MONTHLY
  WEEKLY
  CUSTOM
}

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  password         String
  profilePicUrl    String?
  type             UserType @default(FREE)
  stripeCustomerId String?  @unique()
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt()

  //oauth
  googleId           String?   @unique
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?

  //relations
  accounts           Accounts[]
  categories         Category[]
  transactions       Transactions[]
  subscriptions      Subscription[]
  analyticsSnapshots AnalyticsSnapshots[]
  taxes              Taxes[]
  transfers          Transfers[]
  budgets            Budget[]
}

model Accounts {
  id                String             @id @default(cuid())
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  name              String
  type              AccountType        @default(PERSONAL)
  currency          Currency           @default(NPR)
  balance           Decimal
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  transactions      Transactions[]
  outgoingTransfers Transfers[]        @relation("FromAccount")
  incomingTransfers Transfers[]        @relation("ToAccount")
  budgetAllocations BudgetAllocation[]
}

model Transactions {
  id               String             @id @default(cuid())
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  account          Accounts           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId        String
  type             TransactionType
  amount           Decimal
  transactionDate  DateTime
  category         Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId       String
  subcategory      SubCategory?       @relation(fields: [subCategoryId], references: [id])
  subCategoryId    String?
  note             String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt()
  transactionTaxes TransactionTaxes[]

  @@index([id])
  @@index([userId])
  @@index([accountId])
  @@index([transactionDate])
}

model Category {
  id                String             @id @default(cuid())
  name              String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  transactions      Transactions[]
  subCategories     SubCategory[]
  budgetAllocations BudgetAllocation[]
}

model SubCategory {
  id           String         @id @default(cuid())
  name         String?
  category     Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId   String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  transactions Transactions[]
}

model Subscription {
  id                   String             @id @default(cuid())
  user                 User               @relation(fields: [userId], references: [id])
  userId               String
  price                Decimal
  startDate            DateTime
  status               SubscriptionStatus @default(EXPIRED)
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Transfers {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  fromAccount   Accounts @relation("FromAccount", fields: [fromAccountId], references: [id])
  fromAccountId String
  toAccount     Accounts @relation("ToAccount", fields: [toAccountId], references: [id])
  toAccountId   String
  amount        Decimal
  transferDate  DateTime
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt()
}

model AnalyticsSnapshots {
  id                 String   @id @default(cuid())
  user               User     @relation(fields: [userId], references: [id])
  userId             String
  snapshotDate       DateTime
  totalIncome        Decimal
  totalExpense       Decimal
  networth           Decimal
  categorySummary    Json
  subCategorySummary Json
  accountSummary     Json
}

model Taxes {
  id               String             @id @default(cuid())
  user             User               @relation(fields: [userId], references: [id])
  userId           String
  name             String?
  rate             Decimal
  type             TaxType
  transactionTaxes TransactionTaxes[]
}

model TransactionTaxes {
  id            String       @id @default(cuid())
  transaction   Transactions @relation(fields: [transactionId], references: [id])
  transactionId String
  tax           Taxes        @relation(fields: [taxId], references: [id])
  taxId         String
  amount        Decimal
}

model Budget {
  id                String             @id @default(cuid())
  user              User               @relation(fields: [userId], references: [id])
  userId            String
  name              String?
  period            BudgetPeriod
  startDate         DateTime
  endDate           DateTime
  totalLimit        Decimal?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt()
  budgetAllocations BudgetAllocation[]
}

model BudgetAllocation {
  id         String    @id @default(cuid())
  budget     Budget    @relation(fields: [budgetId], references: [id])
  budgetId   String
  // category budget
  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?
  // account budget
  account    Accounts? @relation(fields: [accountId], references: [id])
  accountId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()
}
